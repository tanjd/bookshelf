# =============================================================================
# Backend Configuration (Go)
# =============================================================================

# Environment: "dev" or "prd"
ENV=dev

# Server port
PORT=8000

# Path to SQLite database file
DB_PATH=./data/bookshelf.db

# JWT signing secret (change in production!)
JWT_SECRET=changeme-use-a-long-random-string

# CORS origins allowed to call the API (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Resend API key for transactional email (optional — disable email if empty)
RESEND_API_KEY=

# Email sender address
EMAIL_FROM=noreply@yourdomain.com

# =============================================================================
# Frontend Configuration
# =============================================================================

# Backend API URL (used by Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000
