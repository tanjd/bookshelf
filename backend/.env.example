# =============================================================================
# Backend Configuration (Go)
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Environment: "dev" or "prd"
ENV=dev

# Server port
PORT=8000

# Path to SQLite database file (relative to backend/)
DB_PATH=./data/bookshelf.db

# JWT signing secret (change in production!)
JWT_SECRET=changeme-use-a-long-random-string

# CORS origins allowed to call the API (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Resend API key for transactional email (optional — disable email if empty)
RESEND_API_KEY=

# Email sender address
EMAIL_FROM=noreply@yourdomain.com

# Dev-only: redirect all outgoing emails to this address when ENV=dev (optional)
DEV_EMAIL_OVERRIDE=

# How often the background job refreshes cached book metadata (Go duration, e.g. 1h, 24h)
METADATA_REFRESH_INTERVAL=24h

# =============================================================================
# Book metadata
# =============================================================================

# Google Books API key (optional — Open Library is always used; Google Books skipped if empty)
GOOGLE_BOOKS_API_KEY=

# =============================================================================
# App config
# =============================================================================

# Path to bookshelf.yaml for seeding app settings on startup (optional).
# If the file exists, its values override the DB defaults at boot time.
# Generate a bookshelf.yaml snapshot from the Admin UI → Settings → Export YAML.
# APP_CONFIG_PATH=./bookshelf.yaml
